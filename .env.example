# Kopiere diese Datei nach .env und passe die Werte an:  cp .env.example .env

# Pflicht: Secret für das verschlüsselte Login-Cookie (mindestens 32 Zeichen).
# Erzeugen z. B. mit:  openssl rand -hex 32
HOMEPAGE_SESSION_SECRET=

# Erlaubte Host(s) für den Zugriff. Default erlaubt nur localhost:3000.
# Bei Zugriff über IP/Domain hier eintragen (kommagetrennt), z. B.:
#   HOMEPAGE_ALLOWED_HOSTS=192.168.14.10:3000,homepage.local:3000
# Oder "*" um die Host-Prüfung zu deaktivieren.
HOMEPAGE_ALLOWED_HOSTS=localhost:3000

# Das fertige Image auf Docker Hub (nur für den Server-Pull bzw. das Push-Skript).
# Trage hier deinen Docker-Hub-Benutzernamen ein:
DOCKERHUB_IMAGE=deinuser/homepage-kito:latest
